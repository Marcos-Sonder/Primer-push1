if(typeof jQuery=='undefined'){console.log("RAIDBOXES trkref plugin: jQuery is required")}else{var RB_COOKIE_NAME="rbreftrked";if(getCookie(RB_COOKIE_NAME)!="1"){console.log('create cookie');var referer=document.referrer;console.log("referer: "+referer);if(referer!=null&&referer!=''){var expiryDate=new Date();expiryDate.setDate(expiryDate.getDate()+60);setCookie(RB_COOKIE_NAME,"1",{secure:!0,expires:expiryDate,samesite:'None',domain:window.location.host});const url="https://dashboard.raidboxes.de/trckrf?r="+encodeURI(referer)+"&lp="+encodeURI(location.href)
jQuery.getScript(url)}}
function setCookie(name,value,options={}){options={path:'/',...options};if(options.expires instanceof Date){options.expires=options.expires.toUTCString()}
let updatedCookie=encodeURIComponent(name)+"="+encodeURIComponent(value);for(let optionKey in options){updatedCookie+="; "+optionKey;let optionValue=options[optionKey];if(optionValue!==!0){updatedCookie+="="+optionValue}}
document.cookie=updatedCookie}
function getCookie(cname){var name=cname+"=";var decodedCookie=decodeURIComponent(document.cookie);var ca=decodedCookie.split(';');for(var i=0;i<ca.length;i++){var c=ca[i];while(c.charAt(0)==' '){c=c.substring(1)}
if(c.indexOf(name)==0){return c.substring(name.length,c.length)}}
return""}}